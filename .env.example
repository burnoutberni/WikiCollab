# Comma-separated list of allowed CORS origins for both HTTP and WebSocket connections.
# Defaults to http://localhost:5173,http://localhost:3001 when unset.
# Origins must be exact (no trailing slash, lowercase scheme/host).
# CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# Rate limiting configuration
# Document CRUD operations (per IP, per window)
# RATE_LIMIT_CRUD_MAX=100
# RATE_LIMIT_CRUD_WINDOW=60

# Preview and CSS proxy endpoints (per IP, per window)
# RATE_LIMIT_PREVIEW_MAX=60
# RATE_LIMIT_PREVIEW_WINDOW=60

# Push to wiki endpoint (per IP, per window)
# RATE_LIMIT_PUSH_MAX=10
# RATE_LIMIT_PUSH_WINDOW=60

# WebSocket connections (per IP)
# RATE_LIMIT_WS_CONCURRENT=100   # Max simultaneous connections
# RATE_LIMIT_WS_RATE_MAX=100     # Max connection attempts per window
# RATE_LIMIT_WS_RATE_WINDOW=60
