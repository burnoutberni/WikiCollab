{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":pinDockerImages"
  ],
  "packageRules": [
    {
      "description": "Group all GitHub Actions updates into one weekly PR",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "pinDigests": true,
      "schedule": ["before 9am on Monday"]
    },
    {
      "description": "Group non-breaking npm devDependencies weekly",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "devDependencies (non-breaking)",
      "schedule": ["before 9am on Monday"],
      "automerge": true
    },
    {
      "description": "Group non-breaking npm production deps weekly",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "production dependencies (non-breaking)",
      "schedule": ["before 9am on Monday"]
    },
    {
      "description": "Separate major version bumps for manual review",
      "matchUpdateTypes": ["major"],
      "labels": ["major-update"],
      "schedule": ["before 9am on Monday"]
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on Monday"]
  },
  "rangeStrategy": "bump",
  "labels": ["dependencies"],
  "semanticCommits": "enabled"
}
